[ghq]
	root = ~/dev
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge --skip -- %f
	process = git-lfs filter-process --skip
	required = true
[log]
	date = iso
[gtr "editor"]
	default = emacs
[gtr "ai"]
	default = "copilot --allow-all-tools --deny-tool=\"shell(git push)\" --deny-tool=\"shell(git push:*)\" --deny-tool=\"shell(rm)\""
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
[merge]
	conflictstyle = zdiff3
[include]
	path = ~/.gitconfig.local
